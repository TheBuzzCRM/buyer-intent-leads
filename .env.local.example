# Environment variables for Buyer Intent Leads
# Copy to .env.local and fill in real values

# Neon DB connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb"

# JWT secret (generate with `openssl rand -base64 32`)
JWT_SECRET="your-jwt-secret-here"

# Next.js public URL
NEXT_PUBLIC_SITE_URL="https://buyerintentleads.com"

# Admin credentials (initial admin)
ADMIN_EMAIL="admin@buyerintentleads.com"
ADMIN_PASSWORD="change-me"

# Optional: Google Analytics, Meta Pixel, etc.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""
